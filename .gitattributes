#----------------------------------------
#
#   General Git Config
#
#----------------------------------------

# Normalize EOL for all files that Git considers text files.
* text=auto eol=lf

#----------------------------------------
#
#   LFS
#
#----------------------------------------

# Binary & Libraries
*.exe filter=lfs diff=lfs merge=lfs -text
*.exp filter=lfs diff=lfs merge=lfs -text
*.lib filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text
*.so filter=lfs diff=lfs merge=lfs -text
*.dylib filter=lfs diff=lfs merge=lfs -text

# Archives
*.rar filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text

# General Texture/Art
*.png filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.xcf filter=lfs diff=lfs merge=lfs -text
*.kra filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text

# General 3D
*.blend filter=lfs diff=lfs merge=lfs -text
*.blend1 filter=lfs diff=lfs merge=lfs -text
*.glb filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.f3d filter=lfs diff=lfs merge=lfs -text
*.dwg filter=lfs diff=lfs merge=lfs -text

# Music & Sound
*.wav filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.flp filter=lfs diff=lfs merge=lfs -text
*.logicx filter=lfs diff=lfs merge=lfs -text
*.oib filter=lfs diff=lfs merge=lfs -text
*.opb filter=lfs diff=lfs merge=lfs -text
*.mid filter=lfs diff=lfs merge=lfs -text
*.midi filter=lfs diff=lfs merge=lfs -text
*.nksfx filter=lfs diff=lfs merge=lfs -text
*.plist filter=lfs diff=lfs merge=lfs -text
*.ffp filter=lfs diff=lfs merge=lfs -text
*.mmpz filter=lfs diff=lfs merge=lfs -text
*DisplayStateArchive filter=lfs diff=lfs merge=lfs -text
*ProjectData filter=lfs diff=lfs merge=lfs -text
*.aup3 filter=lfs diff=lfs merge=lfs -text
*.aup3-shm filter=lfs diff=lfs merge=lfs -text
*.aup3-wal filter=lfs diff=lfs merge=lfs -text

# Video
*.mov filter=lfs diff=lfs merge=lfs -text
*.ogv filter=lfs diff=lfs merge=lfs -text
*.drp filter=lfs diff=lfs merge=lfs -text

# Singularity Specific LFS
*.sgra filter=lfs diff=lfs merge=lfs -text
*.sgrb filter=lfs diff=lfs merge=lfs -text
*.sgrw filter=lfs diff=lfs merge=lfs -text

# Random Debugging
*.bin filter=lfs diff=lfs merge=lfs -text