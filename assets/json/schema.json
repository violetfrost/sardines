{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sardines Deck Schema",
  "type": "object",
  "properties": { 
    "version": {
      "type": "integer"
    },
    "deck": {
      "name": {
        "type": "string"
      },
      "categories": {
        "type": "array",
        "maxItems": "9"
      },
      "required": [
        "name",
        "categories"
      ]
    },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "favorited": {
            "type": "boolean"
          },
          "category": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "text"
        ]
      }
    }
  },
  "required": [
    "version",
    "deck",
    "cards"
  ]
}