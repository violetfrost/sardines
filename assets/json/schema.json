{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sardines Deck Schema",
  "type": "object",
  "properties": {
    "deck_name": {
      "type": "string"
    },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "favorited": {
            "type": "boolean"
          },
          "category": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "text"
        ]
      }
    }
  },
  "required": [
    "deck_name",
    "cards"
  ]
}